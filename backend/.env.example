# ============================================================
# ET AI Concierge Backend - Environment Variables
# For Railway Deployment
# ============================================================

# 1. CORS Configuration (REQUIRED)
# Add your Vercel frontend URL here to allow requests
# Format: comma-separated list of allowed origins
# For local dev: http://localhost:3000,http://127.0.0.1:3000
# For Vercel: https://your-project.vercel.app
CORS_ALLOWED_ORIGINS=https://your-project.vercel.app

# 2. Hugging Face API Token (RECOMMENDED for production)
# Get token from: https://huggingface.co/settings/tokens
# What it does: Uses HF Inference API instead of local model downloads
# Benefits:
#   - Faster persona detection and embeddings
#   - No large model downloads on container startup
#   - Better performance + lower memory usage
# Leave empty to use local fallback (slower, larger container)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# 3. Hugging Face Models (OPTIONAL - only used if HF_API_TOKEN is set)
# If not specified, defaults are used

# Zero-shot classification model for persona detection
# Default: facebook/bart-large-mnli
# Other options: facebook/bart-large-mnli, joeddav/bart-large-mnli-yahoo-answers
HF_ZERO_SHOT_MODEL=facebook/bart-large-mnli

# Sentence embedder model for product ranking
# Default: sentence-transformers/all-MiniLM-L6-v2
# Other options: sentence-transformers/all-MiniLM-L12-v2, sentence-transformers/all-mpnet-base-v2
HF_EMBEDDER_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================
# DEPLOYMENT CHECKLIST
# ============================================================
# 1. Get HF Token: https://huggingface.co/settings/tokens
# 2. In Railway Dashboard:
#    - Go to: Project → Variables
#    - Add all vars above
#    - Set CORS_ALLOWED_ORIGINS = your Vercel URL
#    - Set HF_API_TOKEN = your token
# 3. Redeploy after adding vars
# 4. Test: https://your-backend.up.railway.app/docs
